+
+long long arepo_get_hydro_timebins(int *bins, int *active, int *sync, int *active_list,
+                                     long long *ti_current, double *timebase_interval,
+                                     long n, long long max_active)
+{
+  if(!bridge_initialized || bins == NULL || active == NULL || sync == NULL || active_list == NULL ||
+     ti_current == NULL || timebase_interval == NULL)
+    return -1;
+  if(n != (long)NumGas)
+    return -2;
+
+  long long required = (long long)TimeBinsHydro.NActiveParticles;
+  if(max_active < required)
+    return -required;
+
+  for(long i = 0; i < n; i++)
+    {
+      bins[i]   = P[i].TimeBinHydro;
+      active[i] = TimeBinSynchronized[P[i].TimeBinHydro] ? 1 : 0;
+    }
+
+  for(int b = 0; b < TIMEBINS; b++)
+    sync[b] = TimeBinSynchronized[b] ? 1 : 0;
+
+  for(long long k = 0; k < required; k++)
+    active_list[k] = TimeBinsHydro.ActiveParticleList[k];
+
+  *ti_current        = (long long)All.Ti_Current;
+  *timebase_interval = All.Timebase_interval;
+  return required;
+}
 
